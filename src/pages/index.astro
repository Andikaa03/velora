  { label: "FAQ", href: "#faq" },
];

const trustItems = ["Premium visual direction", "Responsive development", "Domain & hosting setup", "Launch support included"];

const companyLogos = [
  { name: "Aidn", src: "/assets/logo-aidn.svg", className: "h-[36px] w-[81px]" },
  { name: "Zapier", src: "/assets/logo-zapier.svg", className: "h-[34px] w-[121px]" },
  { name: "Mercury", src: "/assets/logo-mercury.svg", className: "h-[22px] w-[121px]" },
