const weeklyCards = [
  {
    title: "Premium Landing Page",
    copy: "Offer, page sections, CTA flow, responsive layout, and visual polish prepared for launch.",
    image: "/assets/unsplash-dashboard-phone.jpg",
    avatar: "/assets/weekly-avatar-brent.png",
    author: "Velora Studio",
    meta: "#Landing Page",
    reaction: "Launch checklist added",
    icon: "lucide:rocket",
  },
  {
    title: "Business Website Redesign",
    copy: "Homepage and core pages refined into a clearer, more trusted brand presence.",
    image: "/assets/unsplash-code-hands.jpg",
    avatar: "/assets/weekly-avatar-lea.png",
    author: "Project Review",
    meta: "#Redesign",
    reaction: "Visual direction approved",
    icon: "lucide:sparkles",
  },
];

const featureItems = [
  { title: "Landing Pages", copy: "Focused pages for offers, products, services, campaigns, and personal brands.", icon: "lucide:mouse-pointer-click" },
  { title: "Business Websites", copy: "Multi-page websites with clear structure, polished visuals, and strong CTAs.", icon: "lucide:panel-top" },
  { title: "Website Redesign", copy: "Refresh your current website into a premium presence that fits your brand today.", icon: "lucide:refresh-cw" },
  { title: "Ecommerce Websites", copy: "Product-focused web experiences for brands preparing to sell online.", icon: "lucide:shopping-bag" },
  { title: "SaaS & Product Sites", copy: "Marketing websites for apps, platforms, dashboards, and digital products.", icon: "lucide:blocks" },
  { title: "CMS Websites", copy: "Content-ready websites using WordPress, Webflow, Framer, or custom code.", icon: "lucide:layout-template" },
];

const platforms = [
  { title: "Custom Code", copy: "Fast, flexible, and tailored for a polished experience.", icon: "lucide:code-2" },
  { title: "WordPress", copy: "Ideal for blogs, content-heavy websites, and easy updates.", icon: "simple-icons:wordpress" },
  { title: "Framer", copy: "Great for modern landing pages with smooth visual polish.", icon: "simple-icons:framer" },
  { title: "Webflow", copy: "Perfect for visual websites with structured CMS needs.", icon: "simple-icons:webflow" },
];

const pricingPlans = [
  {
    name: "Landing Page",
    price: "Rp 1.000.000",
    description: "For one focused, premium page built to present one offer clearly.",
    cta: "Start Project",
    href: whatsappUrl,
    features: ["1 premium landing page", "Responsive development", "Basic animation", "Copy structure support", "Domain & hosting setup", "Launch support"],
  },
  {
    name: "Business Website",
    price: "Rp 2.500.000",
    description: "For brands that need a stronger and more complete online presence.",
    cta: "Start Project",
    href: whatsappUrl,
    featured: true,
    features: ["Multi-page website", "Home, about, services, contact", "Premium visual direction", "Basic SEO setup", "Domain & hosting setup", "Launch support"],
  },
  {
    name: "Growth Website",
    price: "Rp 4.500.000",
    description: "For brands preparing for a more scalable premium digital presence.",
    cta: "Start Project",
    href: whatsappUrl,
    features: ["Premium multi-page website", "CMS/blog-ready structure", "Refined visual system", "Smooth animation", "Domain & hosting setup", "Launch support"],
  },
  {
    name: "Custom Project",
    price: "Contact Us",
    description: "For ecommerce, SaaS, integrations, custom features, or larger scopes.",
    cta: "Discuss Project",
    href: calendlyUrl,
    features: ["Tailored project scope", "Ecommerce or SaaS website", "Custom-coded experience", "CMS and integrations", "Advanced animation", "Scalable foundation"],
  },
];

const comparisonRows = [
  { label: "Timeline", velora: "Focused sprint with launch support", typical: "Longer timeline and heavier meetings" },
  { label: "Process", velora: "Direction, design, build, and launch in one flow", typical: "More handoffs between strategy, design, and development" },
  { label: "Budget", velora: "Opening pricing for selected early projects", typical: "Higher starting budget before production begins" },
  { label: "Scope", velora: "Landing pages, redesigns, business websites, ecommerce, and SaaS", typical: "Often packaged around fixed agency retainers" },
];

const faqItems = [
  {
    question: "Can you redesign an existing website?",
    answer: "Yes. We can redesign your current website into a clearer, sharper, and more premium online presence.",
  },
  {
    question: "Is domain and hosting included?",
    answer: "Domain and hosting setup support is included, so your website can be prepared and launched smoothly.",
  },
  {
    question: "Can you build ecommerce or SaaS websites?",
    answer: "Yes. Ecommerce, SaaS, product websites, custom features, and integrations are handled through Custom Project scope.",
  },
  {
    question: "Which platform should I choose?",
    answer: "We can recommend the best setup after understanding your goals. Custom code, WordPress, Framer, and Webflow are available.",
  },
  {
    question: "Is this promo pricing permanent?",
    answer: "No. These are opening prices for selected early projects while project slots are still limited.",
  },
];

const footerGroups = [
  { title: "Studio", links: [{ label: "Services", href: "#features" }, { label: "Process", href: "#how-it-works" }, { label: "Pricing", href: "#pricing" }, { label: "FAQ", href: "#faq" }] },
  { title: "Projects", links: [{ label: "Landing Pages", href: "#pricing" }, { label: "Business Websites", href: "#pricing" }, { label: "Website Redesign", href: "#features" }, { label: "Custom Projects", href: "#pricing" }] },
  { title: "Contact", links: [{ label: "Book a Consultation", href: calendlyUrl }, { label: "Chat on WhatsApp", href: whatsappUrl }] },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Velora Studio builds premium websites for brands ready to grow." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <title>Velora Studio | Premium Websites for Growing Brands</title>
  </head>
  <body class="bg-[var(--current-lime)]">
    <main class="min-h-screen bg-[var(--current-lime)] text-[var(--current-ink)]">
      <ScrollMotionController client:load />
      <header class="sticky top-0 z-50 w-full bg-[var(--current-lime)]">
        <nav class="mx-auto flex h-[75px] w-full max-w-[1440px] items-center justify-between px-5 sm:px-8 lg:px-12">
          <a href="/" aria-label="Velora Studio home" class="flex h-12 min-w-0 items-center overflow-hidden">
            <img src="/assets/velora-logo-transparent.png" alt="Velora" class="h-[40px] w-[168px] object-contain object-left sm:h-[44px] sm:w-[198px] lg:h-[46px] lg:w-[210px]" />
          </a>

          <div class="hidden items-center gap-1 lg:flex">
            {navItems.map((item) => <a href={item.href} class="flex h-[43px] items-center rounded-full px-3 text-[17px] leading-[23px] text-[#242424] transition hover:bg-[#d7ef69]">{item.label}</a>)}
            <span class="mx-2 h-4 w-px bg-[var(--current-lime-line)]" aria-hidden="true"></span>
            <a href={whatsappUrl} class="flex h-[43px] items-center rounded-full px-3 text-[17px] leading-[23px] text-[#242424] transition hover:bg-[#d7ef69]">WhatsApp</a>
            <a href={calendlyUrl} class="flex h-[43px] items-center rounded-full bg-[#242424] px-6 text-[17px] leading-[23px] text-[#f0f0f0] transition hover:bg-black">Book a call</a>
          </div>

          <div class="flex items-center gap-2 lg:hidden">
            <a href={whatsappUrl} class="hidden h-[43px] items-center rounded-full px-3 text-[15px] text-[#242424] transition hover:bg-[#d7ef69] sm:flex">WhatsApp</a>
            <a href={calendlyUrl} class="flex h-[43px] items-center rounded-full bg-[#242424] px-5 text-[16px] text-[#f0f0f0]">Book</a>
          </div>
        </nav>
      </header>

      <section class="mx-auto flex w-full max-w-[1440px] flex-col items-center px-6 pb-8 pt-8 text-center sm:pt-[21px]">
        <div data-reveal class="max-w-[1080px]">
          <p class="mx-auto mb-5 w-fit rounded-full border border-[var(--current-lime-line)] px-4 py-2 text-[13px] uppercase leading-none tracking-[1.8px] text-[var(--current-primary)]">
            Opening slots available - promo pricing for early clients
          </p>
          <h1 class="mx-auto max-w-[1080px] text-[clamp(48px,7.1vw,101px)] font-black leading-[0.997] tracking-[-0.025em] text-[#1e1e1e]">
            Premium websites for<br class="hidden sm:block" /> brands ready to grow
          </h1>
          <p class="mx-auto mt-6 max-w-[900px] text-[20px] leading-[1.4] tracking-[-0.004em] text-[rgba(91,100,54,0.85)] sm:text-2xl">
            We design and build polished websites for growing brands. From landing pages and business websites to future-ready
            <span class="text-[#1e1e1e]">ecommerce</span>, <span class="text-[#1e1e1e]">SaaS</span>, and <span class="text-[#1e1e1e]">custom web experiences</span>.
          </p>
        </div>

        <div data-reveal class="mt-9 flex w-full max-w-[570px] flex-col items-center gap-3 sm:flex-row sm:gap-4">
          <a href={calendlyUrl} class="flex h-[66px] w-full items-center justify-center rounded-full bg-[#242424] px-8 text-[19px] font-medium leading-[26px] text-white transition hover:bg-black sm:w-[285px]">Book a Free Consultation</a>
          <a href={whatsappUrl} class="flex h-[68px] w-full items-center justify-center gap-3 rounded-full border border-[var(--current-lime-line)] px-8 text-[19px] font-medium leading-[26px] text-[#242424] transition hover:bg-[#d7ef69] sm:w-[250px]">Chat on WhatsApp</a>
        </div>
        <p class="mt-3 text-[15px] leading-[23px] text-[var(--current-muted)]">Domain setup included for opening projects</p>
      </section>

      <section data-scroll-scene class="relative mx-auto mt-7 w-full max-w-[1425px] px-5 pb-20 sm:px-10 lg:px-0">
        <div class="pointer-events-none absolute left-1/2 top-0 z-0 hidden h-12 w-[1425px] -translate-x-1/2 overflow-visible md:block" aria-hidden="true">
          <div data-float class="absolute left-[1060.73px] top-[-81.77px] flex size-[101.54px] items-center justify-center">
            <div class="relative size-[78px] rotate-[22deg] overflow-hidden">
              <img src="/assets/deco-figma-bg.svg" alt="" class="absolute left-[-1px] top-0 size-[79px]" />
              <img src="/assets/deco-figma-mark.svg" alt="" class="absolute left-[20px] top-[12px] h-[56px] w-[40px]" />
            </div>
          </div>
          <div data-float class="absolute left-[479px] top-[-50px] size-[87px] rounded-full bg-[var(--current-lime-line)]">
            <img src="/assets/deco-rays.svg" alt="" class="absolute left-[11px] top-[11px] size-[65px]" />
          </div>
          <div data-float class="absolute left-[1261.4px] top-[-113.1px] flex size-[42.208px] items-center justify-center">
            <div class="relative size-9 rotate-[11deg] overflow-hidden">
              <img src="/assets/deco-small-bg.svg" alt="" class="absolute left-[-1px] top-0 size-[37px]" />
              <img src="/assets/deco-small-mark.svg" alt="" class="absolute left-[6px] top-[6px] h-[25px] w-[26px]" />
            </div>
          </div>
          <div data-float class="absolute left-[886.83px] top-[-41.17px] flex size-[50.341px] items-center justify-center">
            <div class="relative size-11 rotate-[9deg] overflow-hidden rounded-[9px] bg-[var(--current-lime-line)]">
              <img src="/assets/deco-drive.svg" alt="" class="absolute left-[6px] top-[7px] h-[29px] w-[31px]" />
            </div>
          </div>
          <div data-float class="absolute left-[288.11px] top-[-129.89px] flex size-[107.778px] items-center justify-center">
            <div class="relative size-[88px] rotate-[-15deg] overflow-hidden">
              <img src="/assets/deco-notion-bg.svg" alt="" class="absolute left-px top-px size-[86px]" />
              <img src="/assets/deco-notion-mark.svg" alt="" class="absolute left-[7px] top-[7px] size-[74px]" />
            </div>
          </div>
          <div data-float class="absolute left-[174.36px] top-[-27.14px] flex size-[50.285px] items-center justify-center">
            <div class="relative size-9 rotate-[-36deg] overflow-hidden rounded-[9px] bg-[var(--current-lime-line)] shadow-[0_0.452px_0.904px_rgba(16,24,40,0.05)]">
              <img src="/assets/deco-left-small.svg" alt="" class="absolute left-[5px] top-[6px] h-[25px] w-[26px]" />
            </div>
          </div>
        </div>

        <div data-reveal data-card-motion data-scroll-hero class="relative z-10 mx-auto max-w-[1200px] overflow-hidden rounded-2xl bg-gradient-to-br from-white/60 to-black/20 p-2 shadow-[0_5px_56px_rgba(100,114,50,0.24)]">
          <div class="overflow-hidden rounded-[9px]">
            <img src="/assets/unsplash-laptop-web.jpg" alt="Premium laptop workspace for Velora Studio" class="motion-image block aspect-[1.88] w-full rounded-[9px] object-cover transition duration-[900ms] ease-out" />
          </div>
        </div>
      </section>

      <section id="good-company" class="pt-[100px]">
        <p data-reveal class="text-center text-[16.9px] uppercase leading-4 tracking-[2px] text-[var(--current-muted)]">YOU’RE IN GOOD COMPANY</p>
        <div data-reveal class="mx-auto mt-12 flex max-w-[1128px] snap-x overflow-x-auto px-6 sm:px-0">
          <div class="flex size-[188px] shrink-0 snap-start items-center justify-center rounded border-b border-l border-t border-[var(--current-lime-line)]">
            <img src="/assets/logo-aidn.svg" alt="Aidn" class="h-[36px] w-[81px]" />
          </div>
          <div class="flex size-[188px] shrink-0 snap-start items-center justify-center gap-[8px] rounded border-b border-l border-t border-[var(--current-lime-line)]">
            <img src="/assets/logo-synthesia.svg" alt="" class="size-[26px]" />
            <img src="/assets/logo-synthesia-word.svg" alt="Synthesia" class="h-[16px] w-[90px]" />
          </div>
          {
            companyLogos.slice(1).map((logo) => (
              <div class="flex size-[188px] shrink-0 snap-start items-center justify-center rounded border-b border-l border-t border-[var(--current-lime-line)] last:border-r">
                <img src={logo.src} alt={logo.name} class={logo.className} />
              </div>
            ))
          }
        </div>
      </section>

      <section id="how-it-works" data-scroll-scene data-work-scroll class="relative mt-[100px] overflow-hidden bg-[#121212] pb-0 pt-[145px] text-white">
        <img src="/assets/work-bg-left.svg" alt="" class="pointer-events-none absolute left-[-18px] top-[145px] hidden h-[581px] w-[547px] opacity-80 lg:block" />
        <img src="/assets/work-bg-bottom.svg" alt="" class="pointer-events-none absolute left-1/2 top-[576px] hidden h-[416px] w-[400px] -translate-x-[43%] opacity-80 lg:block" />
        <img src="/assets/work-bg-right.svg" alt="" class="pointer-events-none absolute right-[-18px] top-[195px] hidden h-[543px] w-[226px] opacity-80 lg:block" />

        <div class="pointer-events-none absolute left-1/2 top-0 hidden h-[772px] w-[1425px] -translate-x-1/2 lg:block" aria-hidden="true">
          <img src="/assets/work-icon-figma.svg" alt="" class="absolute left-[73px] top-[42px] size-[66px] rotate-[-6deg] rounded-[20px]" />
          <img src="/assets/work-icon-mail.svg" alt="" class="absolute left-[155px] top-[17px] size-[64px]" />
          <img src="/assets/deco-notion-mark.svg" alt="" class="absolute left-[42px] top-[128px] size-[66px] rotate-[-12deg]" />
          <img src="/assets/work-icon-github.svg" alt="" class="absolute left-[1139px] top-[641px] size-11 rotate-[13deg]" />
          <img src="/assets/work-icon-linear.svg" alt="" class="absolute left-[1289px] top-[307px] size-12 rotate-[15deg]" />
          <img src="/assets/work-icon-slack.svg" alt="" class="absolute left-[1231px] top-[474px] size-[58px]" />
          <img src="/assets/work-icon-github.svg" alt="" class="absolute left-[1133px] top-[135px] size-[62px] rotate-[-10deg]" />
          <img src="/assets/deco-left-small.svg" alt="" class="absolute left-[210px] top-[275px] size-10 opacity-70" />
        </div>

        <div data-reveal class="relative z-10 mx-auto max-w-[700px] px-6 text-center">
          <h2 class="text-[clamp(42px,5.6vw,80px)] font-medium leading-[1.02] tracking-[-0.02em]">
            Ideas are often<br />spread everywhere
          </h2>
          <p class="mx-auto mt-5 max-w-[540px] text-[15px] leading-7 text-[#8f8f8f] sm:text-[19.2px]">
            Your offer, visuals, copy, pages, domain, and launch checklist can feel scattered. Velora turns that messy starting point into a clear website direction.
          </p>
        </div>

        <div data-reveal class="relative z-10 mx-auto mt-[190px] max-w-[760px] px-6 text-center">
          <h2 class="text-[clamp(42px,5.6vw,80px)] font-medium leading-[1.02] tracking-[-0.02em]">
            Velora brings it<br />into one clean build
          </h2>
          <p class="mx-auto mt-5 max-w-[540px] text-[15px] leading-7 text-[#8f8f8f] sm:text-[19.2px]">
            We shape the structure, design the visual direction, build the responsive experience, and prepare the website to launch with a premium feel.
          </p>
        </div>

        <div data-reveal class="relative z-10 mx-auto mt-[88px] h-[880px] max-w-[1132px] overflow-hidden px-5 sm:px-0">
          <div class="grid gap-5 md:grid-cols-3">
            <div data-auto-scroll="up" class="flex flex-col gap-5">
              {feedCards.slice(0, 2).map((card) => <article data-card-motion class="overflow-hidden rounded-[4.5px] bg-[#242424] text-left shadow-[0_24px_80px_rgba(0,0,0,0.35)]"><div class="relative h-[296px] overflow-hidden bg-[#424242]"><img src={card.image} alt="" class="motion-image size-full object-cover transition duration-[900ms] ease-out" /><div class="absolute right-3 top-3 flex size-11 items-center justify-center rounded-full bg-[#fcfcfc] text-[#242424]"><iconify-icon icon={card.badgeIcon} class="size-6"></iconify-icon></div></div><div class="border-x border-b border-[#333] px-4 pt-4"><h3 class="text-[17.9px] leading-[27px] text-[#efefef]">{card.title}</h3><p class="mt-2 text-[15.4px] leading-[25.6px] text-[#fdfdfd]">{card.copy}</p><div class="mt-3 flex items-center gap-2 text-[13.2px] leading-[22px] text-[#8f8f8f]"><img src={card.avatar} alt="" class="size-6 rounded-full object-cover" /><span>{card.author} &nbsp;•&nbsp; 1h ago &nbsp;•&nbsp; {card.meta}</span></div><div class="mt-4 border-t border-[rgba(51,51,51,0.5)] py-[18px] text-[13.5px] leading-[21px] tracking-[0.22px] text-[#8f8f8f]">{card.reaction}</div></div></article>)}
            </div>
            <div data-auto-scroll="down" class="mt-8 flex flex-col gap-5 md:mt-[-54px]">
              {feedCards.slice(2).map((card) => <article data-card-motion class="overflow-hidden rounded-[4.5px] bg-[#242424] text-left shadow-[0_24px_80px_rgba(0,0,0,0.35)]"><div class="relative h-[260px] overflow-hidden bg-[#424242]"><img src={card.image} alt="" class="motion-image size-full object-cover transition duration-[900ms] ease-out" /><div class="absolute right-3 top-3 flex size-11 items-center justify-center rounded-full bg-[#fcfcfc] text-[#242424]"><iconify-icon icon={card.badgeIcon} class="size-6"></iconify-icon></div></div><div class="border-x border-b border-[#333] px-4 pt-4"><h3 class="text-[17.9px] leading-[27px] text-[#efefef]">{card.title}</h3><p class="mt-2 text-[15.4px] leading-[25.6px] text-[#fdfdfd]">{card.copy}</p><div class="mt-3 flex items-center gap-2 text-[13.2px] leading-[22px] text-[#8f8f8f]"><img src={card.avatar} alt="" class="size-6 rounded-full object-cover" /><span>{card.author} &nbsp;•&nbsp; 1h ago &nbsp;•&nbsp; {card.meta}</span></div><div class="mt-4 border-t border-[rgba(51,51,51,0.5)] py-[18px] text-[13.5px] leading-[21px] tracking-[0.22px] text-[#8f8f8f]">{card.reaction}</div></div></article>)}
