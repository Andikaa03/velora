---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Velora Studio adalah jasa pembuatan website profesional untuk landing page, company profile, redesign website, WordPress, Framer, Webflow, ecommerce, dan SaaS."
    />
    <meta
      name="keywords"
      content={[...keywordClusters.primary, ...keywordClusters.services].join(", ")}
    />
    <link rel="canonical" href={siteUrl} />
    <link rel="alternate" hreflang="id" href={`${siteUrl}/id/`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/id/`} />
    <meta
      property="og:title"
      content="Jasa Pembuatan Website Profesional | Velora Studio"
    />
    <meta
      property="og:description"
      content="Website premium, cepat, mobile-friendly, dan SEO-ready untuk bisnis yang ingin terlihat lebih dipercaya."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/assets/unsplash-desk-monitor.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <title>Jasa Pembuatan Website Profesional | Velora Studio</title>
    {
      homeSchema.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
  </head>
  <body class="bg-[var(--current-lime)]">
    <main
      class="min-h-screen bg-[var(--current-lime)] text-[var(--current-ink)]"
    >
      <ScrollMotionController client:load />
      <header class="sticky top-0 z-50 w-full bg-[var(--current-lime)]">
        <nav
          class="mx-auto flex h-[75px] w-full max-w-[1440px] items-center justify-between px-5 sm:px-8 lg:px-12"
        >
          <a
            href="/"
            aria-label="Velora Studio home"
            class="flex h-12 min-w-0 items-center overflow-hidden"
          >
            <img
              src="/assets/velora-logo-transparent.png"
              alt="Velora"
              class="h-[40px] w-[168px] object-contain object-left sm:h-[44px] sm:w-[198px] lg:h-[46px] lg:w-[210px]"
            />
          </a>

          <div class="hidden items-center gap-1 lg:flex">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class="flex h-[43px] items-center rounded-full px-2 text-[16px] leading-[23px] text-[#242424] transition hover:bg-[#d7ef69] xl:px-3 xl:text-[17px]"
                >
                  {item.label}
                </a>
              ))
            }
            <span
              class="mx-2 h-4 w-px bg-[var(--current-lime-line)]"
              aria-hidden="true"></span>
            <a
              href={calendlyUrl}
              class="flex h-[43px] items-center rounded-full bg-[#242424] px-6 text-[17px] leading-[23px] text-[#f0f0f0] transition hover:bg-black"
              >Konsultasi</a
            >
            <div class="ml-2 flex rounded-full border border-[#c6df5d] p-1">
              <a
                href="/id"
                class="rounded-full px-3 py-1 text-[14px] text-[#242424] transition hover:bg-[#d7ef69]"
                hreflang="id">ID</a
              >
              <a
                href="/en"
                class="rounded-full px-3 py-1 text-[14px] text-[#242424] transition hover:bg-[#d7ef69]"
                hreflang="en">EN</a
              >
            </div>
          </div>

          <div class="flex items-center gap-2 lg:hidden">
            <button
              type="button"
              data-mobile-menu-open
              aria-label="Open navigation menu"
              class="flex h-[43px] items-center gap-2 rounded-full bg-[#242424] px-5 text-[16px] text-[#f0f0f0]"
            >
              Menu
              <iconify-icon icon="lucide:menu" class="text-[20px]" />
            </button>
          </div>
        </nav>

        <div
          data-mobile-menu
          class="fixed inset-0 z-[60] hidden bg-black/35 lg:hidden"
          aria-hidden="true"
        >
          <button
            type="button"
            data-mobile-menu-close
            aria-label="Close navigation menu"
            class="absolute inset-0 h-full w-full cursor-default"
          >
          </button>
          <div
            data-mobile-menu-panel
            class="absolute right-0 top-0 flex h-full w-[min(86vw,390px)] translate-x-full flex-col bg-[var(--current-lime)] p-5 shadow-[-24px_0_80px_rgba(0,0,0,0.25)] transition-transform duration-500 ease-out"
          >
            <div class="flex items-center justify-between">
              <img
                src="/assets/velora-logo-transparent.png"
                alt="Velora"
                class="h-[40px] w-[168px] object-contain object-left"
              />
              <button
                type="button"
                data-mobile-menu-close
                aria-label="Close navigation menu"
                class="grid size-[44px] place-items-center rounded-full bg-[#242424] text-white"
              >
                <iconify-icon icon="lucide:x" class="text-[22px]" />
              </button>
            </div>

            <nav class="mt-12 flex flex-col gap-2">
              {
                navItems.map((item) => (
                  <a
                    href={item.href}
                    data-mobile-menu-link
                    class="flex min-h-[62px] items-center justify-between rounded-[18px] border border-[var(--current-lime-line)] bg-[#efffa0] px-5 text-[24px] leading-8 tracking-[-0.03em] text-[#242424]"
                  >
                    {item.label}
                    <iconify-icon icon="lucide:arrow-up-right" class="text-[24px]" />
                  </a>
                ))
              }
            </nav>

            <div class="mt-auto grid gap-3 pb-4">
              <a
                href={calendlyUrl}
                data-mobile-menu-link
                class="flex min-h-[58px] items-center justify-center rounded-full bg-[#242424] text-[18px] text-white"
                >Konsultasi</a
              >
              <div class="grid grid-cols-2 gap-3">
                <a
                  href="/id"
                  data-mobile-menu-link
                  hreflang="id"
                  class="flex min-h-[52px] items-center justify-center rounded-full border border-[#9fb148] text-[17px] text-[#242424]"
                  >ID</a
                >
                <a
                  href="/en"
                  data-mobile-menu-link
                  hreflang="en"
                  class="flex min-h-[52px] items-center justify-center rounded-full border border-[#9fb148] text-[17px] text-[#242424]"
                  >EN</a
                >
              </div>
            </div>
          </div>
        </div>
      </header>

      <section
        class="mx-auto flex w-full max-w-[1440px] flex-col items-center px-6 pb-8 pt-8 text-center sm:pt-[21px]"
      >
        <div data-reveal class="max-w-[1080px]">
          <p
            class="mx-auto mb-5 w-fit rounded-full border border-[var(--current-lime-line)] px-4 py-2 text-[13px] uppercase leading-none tracking-[1.8px] text-[var(--current-primary)]"
          >
            Slot opening tersedia - harga promo untuk project awal
          </p>
          <h1
            data-reveal
            data-primary-slide
            class="mx-auto max-w-[1080px] text-[clamp(48px,7.1vw,101px)] font-black leading-[0.997] tracking-[-0.025em] text-[#1e1e1e]"
          >
            Jasa pembuatan website<br class="hidden sm:block" /> premium untuk bisnis
          </h1>
          <p
            class="mx-auto mt-6 max-w-[900px] text-[20px] leading-[1.4] tracking-[-0.004em] text-[rgba(91,100,54,0.85)] sm:text-2xl"
          >
            Kami membantu bisnis terlihat lebih dipercaya lewat website yang
            rapi, cepat, mobile-friendly, dan SEO-ready. Mulai dari
            <span class="text-[#1e1e1e]">landing page</span>, <span
              class="text-[#1e1e1e]">company profile</span
            >, <span class="text-[#1e1e1e]">redesign website</span>, sampai
            <span class="text-[#1e1e1e]">ecommerce</span> dan <span
              class="text-[#1e1e1e]">SaaS</span>.
          </p>
        </div>

        <div
          data-reveal
          class="mt-9 flex w-full max-w-[570px] flex-col items-center gap-3 sm:flex-row sm:gap-4"
        >
          <a
            href={calendlyUrl}
            class="flex h-[66px] w-full items-center justify-center rounded-full bg-[#242424] px-8 text-[19px] font-medium leading-[26px] text-white transition hover:bg-black sm:w-[285px]"
            >Konsultasi Gratis</a
          >
          <a
            href={whatsappUrl}
            class="flex h-[68px] w-full items-center justify-center gap-3 rounded-full border border-[var(--current-lime-line)] px-8 text-[19px] font-medium leading-[26px] text-[#242424] transition hover:bg-[#d7ef69] sm:w-[250px]"
            >Chat WhatsApp</a
          >
        </div>
        <p class="mt-3 text-[15px] leading-[23px] text-[var(--current-muted)]">
          Termasuk setup domain & hosting untuk project opening
        </p>
      </section>

      <section
        data-scroll-scene
        class="relative mx-auto mt-7 w-full max-w-[1425px] px-5 pb-20 sm:px-10 lg:px-0"
      >
        <div
          class="pointer-events-none absolute left-1/2 top-0 z-0 hidden h-12 w-[1425px] -translate-x-1/2 overflow-visible md:block"
          aria-hidden="true"
        >
          <div
            data-float
            class="absolute left-[1060.73px] top-[-81.77px] flex size-[101.54px] items-center justify-center"
          >
            <div class="relative size-[78px] rotate-[22deg] overflow-hidden">
              <img
                src="/assets/deco-figma-bg.svg"
                alt=""
                class="absolute left-[-1px] top-0 size-[79px]"
              />
              <img
                src="/assets/deco-figma-mark.svg"
                alt=""
                class="absolute left-[20px] top-[12px] h-[56px] w-[40px]"
              />
            </div>
          </div>
          <div
            data-float
            class="absolute left-[479px] top-[-50px] size-[87px] rounded-full bg-[var(--current-lime-line)]"
          >
            <img
              src="/assets/deco-rays.svg"
              alt=""
              class="absolute left-[11px] top-[11px] size-[65px]"
            />
          </div>
          <div
            data-float
            class="absolute left-[1261.4px] top-[-113.1px] flex size-[42.208px] items-center justify-center"
