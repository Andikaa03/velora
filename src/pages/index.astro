    meta: "#landing-page",
    reaction: "Strategy and design direction approved",
    badgeIcon: "lucide:rocket",
  },
  {
    title: "Business Website System",
    copy: "Homepage, about, services, and contact pages shaped into one clear presence.",
    image: "/assets/unsplash-desk-monitor.jpg",
    avatar: "/assets/work-avatar-scott.png",
    author: "Project Lead",
    meta: "#business-site",
    reaction: "Client-ready structure and launch checklist",
    badgeIcon: "lucide:building-2",
  },
  {
    title: "Redesign Audit Notes",
