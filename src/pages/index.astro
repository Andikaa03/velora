    </main>
    <script>
      import "iconify-icon";
      import Lenis from "lenis";
      import "lenis/dist/lenis.css";

      const lenis = new Lenis({
        autoRaf: true,
      });

      const revealItems = document.querySelectorAll("[data-reveal]");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      revealItems.forEach((item, index) => {
        if (item instanceof HTMLElement) {
          item.style.setProperty(
            "--reveal-delay",
            `${Math.min(index * 55, 220)}ms`,
          );
          item.setAttribute("data-reveal-ready", "");
        }
        observer.observe(item);
      });

      document.documentElement.classList.add("motion-ready");
      requestAnimationFrame(() => {
        revealItems.forEach((item) => {
          if (!(item instanceof HTMLElement)) return;
          const rect = item.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            item.classList.add("is-visible");
          }
        });
      });

      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const mobileMenuPanel = document.querySelector("[data-mobile-menu-panel]");
      const mobileMenuOpen = document.querySelector("[data-mobile-menu-open]");
      const mobileMenuCloseItems = document.querySelectorAll(
        "[data-mobile-menu-close], [data-mobile-menu-link]",
      );

      function setMobileMenu(open: boolean) {
        if (!(mobileMenu instanceof HTMLElement)) return;
        if (!(mobileMenuPanel instanceof HTMLElement)) return;

        if (open) {
          mobileMenu.classList.remove("hidden");
          mobileMenu.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden";
          requestAnimationFrame(() => {
            mobileMenuPanel.style.transform = "translateX(0)";
          });
          return;
        }

        mobileMenuPanel.style.transform = "translateX(100%)";
        mobileMenu.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";
        window.setTimeout(() => {
          mobileMenu.classList.add("hidden");
        }, 450);
      }

      mobileMenuOpen?.addEventListener("click", () => setMobileMenu(true));
      mobileMenuCloseItems.forEach((item) => {
        item.addEventListener("click", () => setMobileMenu(false));
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setMobileMenu(false);
      });

      document.querySelectorAll("[data-faq-question]").forEach((button) => {
        button.addEventListener("click", () => {
          const parent = button.closest("[data-faq-item]");
          parent?.classList.toggle("is-active");
        });
      });

      // Testimonial Slider Logic
      const testimonials = [
        {
          quote:
            "Velora membantu kami mengubah offer yang masih berantakan menjadi website yang terasa premium, jelas, dan siap dikirim ke calon client. Prosesnya fokus, arah desainnya tajam, dan support launch-nya membuat semuanya terasa lebih mudah.",
          name: "Rafi Mahendra",
          role: "Founder, Brand Client",
          avatar: "/assets/testimonial-avatar.png",
          logo: "/assets/testimonial-mercury.svg",
        },
        {
          quote:
            "Akhirnya ketemu studio yang bukan cuma desain, tapi juga benar-benar build dengan cepat. Website baru membuat brand terasa lebih terpercaya di mata calon client.",
          name: "Sarah Lin",
          role: "CMO, Cognite",
          avatar: "/assets/work-avatar-rachel.png",
          logo: "/assets/logo-cognite.svg",
        },
        {
          quote:
            "Arah visualnya tajam dan websitenya terasa cepat. Proses sprint Velora cocok untuk brand modern yang tidak ingin project berlarut-larut.",
          name: "David Chen",
          role: "CEO, Aidn",
          avatar: "/assets/work-avatar-scott.png",
          logo: "/assets/logo-aidn.svg",
        },
      ];

      let currentTsIndex = 0;
      const quoteEl = document.getElementById("ts-quote");
      const avatarEl = document.getElementById("ts-avatar");
      const nameEl = document.getElementById("ts-name");
      const roleEl = document.getElementById("ts-role");
      const logoEl = document.getElementById("ts-logo");
      const authorInfoEl = document.getElementById("ts-author-info");

      function updateTestimonial(index: number) {
        if (
          !quoteEl ||
          !avatarEl ||
          !nameEl ||
          !roleEl ||
          !logoEl ||
          !authorInfoEl
        )
          return;

        const elements = [quoteEl, avatarEl, authorInfoEl, logoEl];

        // Fade out
        elements.forEach((el) => (el.style.opacity = "0"));

        setTimeout(() => {
          const ts = testimonials[index];
          quoteEl.textContent = "“" + ts.quote + "”";
          (avatarEl as HTMLImageElement).src = ts.avatar;
          nameEl.textContent = ts.name;
          roleEl.textContent = ts.role;
          (logoEl as HTMLImageElement).src = ts.logo;

          // Fade in
          elements.forEach((el) => (el.style.opacity = "1"));
        }, 300);
      }

      document.querySelectorAll(".ts-prev").forEach((btn) => {
        btn.addEventListener("click", () => {
          currentTsIndex =
            (currentTsIndex - 1 + testimonials.length) % testimonials.length;
          updateTestimonial(currentTsIndex);
        });
      });

      document.querySelectorAll(".ts-next").forEach((btn) => {
        btn.addEventListener("click", () => {
          currentTsIndex = (currentTsIndex + 1) % testimonials.length;
          updateTestimonial(currentTsIndex);
        });
      });

      const faqItems = Array.from(document.querySelectorAll("[data-faq-item]"));

      function setFaqState(item, open) {
        const trigger = item.querySelector("[data-faq-trigger]");
        const answer = item.querySelector("[data-faq-answer]");
        const icon = item.querySelector("[data-faq-icon]");
        if (
          !(
            trigger instanceof HTMLButtonElement &&
            answer &&
            icon instanceof HTMLElement
          )
        )
          return;

        trigger.setAttribute("aria-expanded", String(open));
        item.setAttribute("data-faq-open", String(open));
        item.classList.toggle("bg-[var(--current-lime)]", open);
        item.classList.toggle("bg-[#f7f7f7]", !open);
        item.classList.toggle("border-[var(--current-lime-line)]", open);
        item.classList.toggle("border-[#dedede]", !open);
        answer.classList.toggle("hidden", !open);
        icon.setAttribute(
          "icon",
          open ? "lucide:arrow-up-right" : "lucide:arrow-down-right",
        );
      }

      faqItems.forEach((item) => {
        const trigger = item.querySelector("[data-faq-trigger]");
        if (!(trigger instanceof HTMLButtonElement)) return;

        trigger.addEventListener("click", () => {
          const isOpen = trigger.getAttribute("aria-expanded") === "true";
          faqItems.forEach((faqItem) => setFaqState(faqItem, false));
          if (!isOpen) setFaqState(item, true);
        });
      });
    </script>
  </body>
</html>
