---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { blogPosts } from "../../data/blogPosts";

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<SiteLayout
  title={`${post.title} | Velora Studio Blog`}
  description={post.excerpt}
  lang="id"
  canonicalPath={`/blog/${post.slug}/`}
>
  <section class="px-6 pb-16 pt-14 lg:pb-24 lg:pt-20">
    <article class="mx-auto max-w-[1120px]">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-full border border-[#c6df5d] px-4 py-2 text-[15px] text-[#242424] transition hover:bg-[#d7ef69]"
      >
        <iconify-icon icon="lucide:arrow-left" class="text-[18px]" />
        Kembali ke blog
      </a>
      <div data-reveal class="mt-10 max-w-[960px]">
        <div
          class="flex flex-wrap items-center gap-3 text-[13px] uppercase tracking-[1.8px] text-[var(--current-primary)]"
        >
          <span>{post.category}</span>
          <span>{post.date}</span>
          <span>{post.readTime}</span>
        </div>
        <h1
          data-reveal
          data-primary-slide
          class="mt-5 text-[clamp(48px,7vw,96px)] font-normal leading-[0.98] tracking-[-0.05em] text-[#242424]"
        >
          {post.title}
        </h1>
        <p class="mt-7 max-w-[780px] text-[22px] leading-8 tracking-[-0.02em] text-[#4f4f4f]">
          {post.excerpt}
        </p>
      </div>

      <div data-reveal class="mt-14 overflow-hidden rounded-lg border border-[#c6df5d]">
        <img src={post.image} alt="" class="h-[360px] w-full object-cover lg:h-[560px]" />
      </div>

      <div class="mx-auto mt-16 grid max-w-[980px] gap-10 lg:grid-cols-[180px_1fr]">
        <aside data-reveal class="hidden lg:block">
          <div class="sticky top-28 rounded-lg border border-[#c6df5d] bg-[#efffa0] p-5">
            <p class="text-[13px] uppercase tracking-[1.8px] text-[var(--current-primary)]">
              Keyword
            </p>
            <p class="mt-4 text-[16px] leading-7 text-[#4f4f4f]">{post.keywords}</p>
          </div>
        </aside>

        <div class="space-y-10">
          {
            post.sections.map((section) => (
              <section data-reveal class="rounded-lg border border-[#dedede] bg-white p-7">
                <h2 class="text-[34px] leading-10 tracking-[-0.03em] text-[#242424]">
                  {section.heading}
                </h2>
                <p class="mt-5 text-[19px] leading-8 text-[#565656]">
                  {section.body}
                </p>
              </section>
            ))
          }

          <section data-reveal class="rounded-lg bg-[#121212] p-7 text-white">
            <p class="text-[14px] uppercase tracking-[2px] text-[var(--current-lime)]">
              Ingin seperti ini untuk brand kamu?
            </p>
            <h2 class="mt-4 text-[38px] leading-[1.05] tracking-[-0.04em]">
              Bangun website yang terasa premium dan lebih mudah dipercaya.
            </h2>
            <a
              href="/contact"
              class="mt-8 inline-flex rounded-full bg-[var(--current-lime)] px-6 py-3 text-[17px] text-[#242424] transition hover:brightness-95"
            >
              Mulai project
            </a>
          </section>
        </div>
      </div>
    </article>
  </section>
</SiteLayout>
