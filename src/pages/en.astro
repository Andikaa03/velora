---
import SiteLayout from "../layouts/SiteLayout.astro";
import { baseServiceSchema } from "../data/seo";

const calendlyUrl = "https://calendly.com/yourname/consultation";
const whatsappUrl = "https://wa.me/628xxxxxxxxxx";

const services = [
  ["Landing Pages", "Focused pages for offers, campaigns, products, and service businesses.", "lucide:mouse-pointer-click"],
  ["Business Websites", "Multi-page websites with clear structure, premium visual direction, and strong CTAs.", "lucide:building-2"],
  ["Website Redesign", "Turn an outdated site into a sharper, clearer, and more trusted online presence.", "lucide:refresh-cw"],
  ["Custom Projects", "Ecommerce, SaaS, CMS, integrations, and custom-coded web experiences.", "lucide:blocks"],
];
---

<SiteLayout
  title="Velora Studio | Premium Website Design and Development"
  description="Velora Studio builds premium landing pages, business websites, redesigns, ecommerce websites, SaaS websites, and custom web experiences."
  lang="en"
  canonicalPath="/en/"
  jsonLd={baseServiceSchema}
>
  <section class="px-6 pb-20 pt-16 lg:pb-28 lg:pt-24">
    <div class="mx-auto grid max-w-[1329px] gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
      <div data-reveal>
        <p class="text-[14px] uppercase tracking-[2px] text-[var(--current-primary)]">
          Premium Website Studio
        </p>
        <h1
          data-reveal
          data-primary-slide
          class="mt-5 max-w-[820px] text-[clamp(48px,7vw,104px)] font-normal leading-[0.96] tracking-[-0.04em] text-[#242424]"
        >
          Premium websites for brands ready to grow.
        </h1>
      </div>
      <div data-reveal class="max-w-[660px] lg:ml-auto">
        <p class="text-[clamp(20px,2.2vw,28px)] leading-[1.35] tracking-[-0.02em] text-[#242424]">
          We design and build polished, responsive, SEO-ready websites for
          landing pages, business websites, redesigns, ecommerce, SaaS, and
          custom digital products.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={calendlyUrl} class="rounded-full bg-[#242424] px-6 py-3 text-[16px] text-white transition hover:bg-black">
            Book a consultation
          </a>
          <a href={whatsappUrl} class="rounded-full border border-[#9fb148] px-6 py-3 text-[16px] text-[#242424] transition hover:bg-[#d7ef69]">
            Chat on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#121212] px-6 py-20 text-white lg:py-28">
    <div class="mx-auto max-w-[1329px]">
      <div data-reveal class="max-w-[760px]">
        <p class="text-[14px] uppercase tracking-[2px] text-[var(--current-lime)]">
          Services
        </p>
        <h2 class="mt-4 text-[clamp(42px,5vw,72px)] font-normal leading-[1] tracking-[-0.04em]">
          Built for launches, redesigns, and future growth.
        </h2>
      </div>
      <div class="mt-14 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {
          services.map(([title, copy, icon]) => (
            <article data-reveal data-card-motion class="rounded-lg border border-[#333] bg-[#1b1b1b] p-6">
              <span class="grid size-[58px] place-items-center rounded-full bg-[var(--current-lime)]">
                <iconify-icon icon={icon} class="text-[34px] text-[#242424]" />
              </span>
              <h3 class="mt-16 text-[30px] leading-9 tracking-[-0.03em]">{title}</h3>
              <p class="mt-4 text-[17px] leading-7 text-[#a9a9a9]">{copy}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</SiteLayout>
